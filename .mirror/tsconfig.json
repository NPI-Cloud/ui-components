{
	"compilerOptions": {
		"jsx": "react-jsx",
		"module": "esnext",
		"moduleResolution": "Bundler",
		"target": "esnext",
		"lib": ["esnext", "dom", "dom.iterable"],
		"strict": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"declaration": true,
		"noEmit": true
	},
	"include": ["src"]
}
