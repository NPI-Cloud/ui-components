{
	"compilerOptions": {
		"composite": true,
		"isolatedModules": true,
		"emitDeclarationOnly": true,
		"declaration": true,
		"module": "esnext",
		"moduleResolution": "Bundler",
		"target": "esnext",
		"lib": ["esnext", "dom", "dom.iterable"],
		"jsx": "react-jsx",
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"outDir": "./dist"
	},
	"include": ["src"]
}
